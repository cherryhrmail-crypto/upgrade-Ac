<!-- pages/profile/profile.wxml — 个人中心 -->
<view class="page">
  <!-- 用户头部 -->
  <view class="user-hero">
    <view class="avatar-wrap">
      <text class="avatar">🌟</text>
    </view>
    <view class="user-info">
      <text class="user-name">小小学者</text>
      <text class="user-level">Level {{currentLevel}} · 优格德学员</text>
    </view>
    <view class="streak-badge">
      <text class="streak-fire">🔥</text>
      <text class="streak-num">{{sd.studyStreak||0}}</text>
      <text class="streak-label">天连续</text>
    </view>
  </view>

  <!-- 总体数据 -->
  <view class="stats-grid">
    <view class="stat-card">
      <text class="sc-num">{{sd.totalDays||0}}</text>
      <text class="sc-label">学习天数</text>
      <text class="sc-icon">📅</text>
    </view>
    <view class="stat-card">
      <text class="sc-num">{{sd.totalWords||0}}</text>
      <text class="sc-label">已学单词</text>
      <text class="sc-icon">📖</text>
    </view>
    <view class="stat-card">
      <text class="sc-num">{{sd.totalStars||0}}</text>
      <text class="sc-label">获得星星</text>
      <text class="sc-icon">⭐</text>
    </view>
    <view class="stat-card">
      <text class="sc-num">{{sd.studyStreak||0}}</text>
      <text class="sc-label">连续天数</text>
      <text class="sc-icon">🔥</text>
    </view>
  </view>

  <!-- 模块进度 -->
  <view class="section">
    <text class="sec-title">📊 学习进度</text>
    <view class="progress-list">
      <view class="prog-item" wx:for="{{progressList}}" wx:key="id">
        <view class="prog-icon" style="background: {{item.bg}}">{{item.emoji}}</view>
        <view class="prog-main">
          <view class="prog-title-row">
            <text class="prog-name">{{item.title}}</text>
            <text class="prog-pct">{{item.pct}}%</text>
          </view>
          <view class="prog-bar-wrap">
            <view class="prog-bar-fill" style="width:{{item.pct}}%; background:{{item.color}}"></view>
          </view>
          <text class="prog-detail">{{item.done}}/{{item.total}} 个</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 成就徽章 -->
  <view class="section">
    <text class="sec-title">🏅 我的成就</text>
    <view class="badges-grid">
      <view class="badge-item {{item.unlocked?'unlocked':'locked'}}" wx:for="{{badges}}" wx:key="id">
        <text class="badge-emoji">{{item.emoji}}</text>
        <text class="badge-name">{{item.name}}</text>
        <text class="badge-cond">{{item.cond}}</text>
      </view>
    </view>
  </view>

  <!-- 设置 -->
  <view class="section">
    <text class="sec-title">⚙️ 设置</text>
    <view class="settings-list">
      <view class="setting-item" bindtap="clearData">
        <text class="setting-icon">🔄</text>
        <text class="setting-label">重置学习记录</text>
        <text class="setting-arrow">›</text>
      </view>
      <view class="setting-item">
        <text class="setting-icon">📞</text>
        <text class="setting-label">联系我们</text>
        <text class="setting-arrow">›</text>
      </view>
      <view class="setting-item">
        <text class="setting-icon">ℹ️</text>
        <text class="setting-label">关于 UpGrade v1.0</text>
        <text class="setting-arrow">›</text>
      </view>
    </view>
  </view>

  <view class="footer-slogan">让每一个孩子爱上英语 🌟</view>
</view>
