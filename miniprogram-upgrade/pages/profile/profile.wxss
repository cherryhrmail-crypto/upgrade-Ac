/* pages/profile/profile.wxss */
.page { background:#F5F7FA; padding-bottom:60rpx; }
/* User Hero */
.user-hero { display:flex; align-items:center; gap:24rpx; padding:50rpx 32rpx 36rpx; background:linear-gradient(135deg,#003a8c,#1976D2); }
.avatar-wrap { width:100rpx; height:100rpx; border-radius:50%; background:rgba(255,255,255,0.2); display:flex; align-items:center; justify-content:center; }
.avatar { font-size:60rpx; }
.user-info { flex:1; }
.user-name { display:block; font-size:36rpx; font-weight:900; color:#fff; }
.user-level { display:block; font-size:24rpx; color:rgba(255,255,255,0.8); margin-top:6rpx; }
.streak-badge { display:flex; flex-direction:column; align-items:center; background:rgba(255,255,255,0.15); border-radius:16rpx; padding:14rpx 20rpx; }
.streak-fire { font-size:32rpx; }
.streak-num { font-size:36rpx; font-weight:900; color:#FFD700; }
.streak-label { font-size:18rpx; color:rgba(255,255,255,0.8); }
/* Stats Grid */
.stats-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:14rpx; padding:24rpx; }
.stat-card { background:#fff; border-radius:20rpx; padding:24rpx 10rpx; display:flex; flex-direction:column; align-items:center; gap:6rpx; box-shadow:0 4rpx 14rpx rgba(0,0,0,0.07); }
.sc-num { font-size:36rpx; font-weight:900; color:#1976D2; }
.sc-label { font-size:20rpx; color:#999; }
.sc-icon { font-size:28rpx; }
/* Section */
.section { margin:0 24rpx 28rpx; }
.sec-title { display:block; font-size:30rpx; font-weight:800; color:#222; margin-bottom:20rpx; }
/* Progress List */
.progress-list { display:flex; flex-direction:column; gap:16rpx; }
.prog-item { background:#fff; border-radius:20rpx; padding:24rpx; display:flex; align-items:center; gap:20rpx; box-shadow:0 4rpx 14rpx rgba(0,0,0,0.06); }
.prog-icon { width:72rpx; height:72rpx; border-radius:18rpx; display:flex; align-items:center; justify-content:center; font-size:36rpx; flex-shrink:0; }
.prog-main { flex:1; }
.prog-title-row { display:flex; justify-content:space-between; margin-bottom:8rpx; }
.prog-name { font-size:28rpx; font-weight:700; color:#333; }
.prog-pct { font-size:26rpx; font-weight:800; color:#1976D2; }
.prog-bar-wrap { height:10rpx; background:#F0F4FF; border-radius:5rpx; overflow:hidden; margin-bottom:6rpx; }
.prog-bar-fill { height:100%; border-radius:5rpx; transition:width 0.5s; }
.prog-detail { font-size:22rpx; color:#aaa; }
/* Badges */
.badges-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16rpx; }
.badge-item { background:#fff; border-radius:20rpx; padding:24rpx 12rpx; display:flex; flex-direction:column; align-items:center; gap:8rpx; box-shadow:0 4rpx 14rpx rgba(0,0,0,0.07); }
.badge-item.locked { opacity:0.45; filter:grayscale(0.8); }
.badge-item.unlocked { border:2rpx solid #FFD700; }
.badge-emoji { font-size:52rpx; }
.badge-name { font-size:24rpx; font-weight:800; color:#333; }
.badge-cond { font-size:20rpx; color:#999; text-align:center; }
/* Settings */
.settings-list { background:#fff; border-radius:20rpx; overflow:hidden; box-shadow:0 4rpx 14rpx rgba(0,0,0,0.06); }
.setting-item { display:flex; align-items:center; gap:20rpx; padding:28rpx 28rpx; border-bottom:1rpx solid #F5F7FA; }
.setting-item:last-child { border-bottom:none; }
.setting-icon { font-size:36rpx; width:52rpx; text-align:center; }
.setting-label { flex:1; font-size:28rpx; color:#333; }
.setting-arrow { font-size:36rpx; color:#ccc; }
/* Footer */
.footer-slogan { text-align:center; padding:20rpx; font-size:24rpx; color:#bbb; }
