<!-- pages/index/index.wxml — 首页 -->
<view class="page">

  <!-- 顶部 Banner -->
  <view class="hero">
    <view class="hero-bg"></view>
    <view class="hero-content">
      <view class="hero-title">
        <text class="title-cn">优格德幼儿英语</text>
        <text class="title-en">UpGrade Kids English</text>
      </view>
      <view class="hero-stats">
        <view class="stat-item">
          <text class="stat-num">{{studyData.totalDays || 0}}</text>
          <text class="stat-label">学习天数</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">{{studyData.totalWords || 0}}</text>
          <text class="stat-label">已学单词</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">{{studyData.studyStreak || 0}}</text>
          <text class="stat-label">连续天数</text>
        </view>
      </view>
    </view>
    <view class="hero-mascot bounce">🌟</view>
  </view>

  <!-- 每日推荐 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">今日推荐</text>
      <text class="section-sub">每天5分钟，进步看得见</text>
    </view>
    <view class="daily-card" bindtap="goToDaily">
      <view class="daily-emoji">{{dailyWord.emoji}}</view>
      <view class="daily-info">
        <text class="daily-word">{{dailyWord.word}}</text>
        <text class="daily-cn">{{dailyWord.cn}}</text>
      </view>
      <view class="daily-arrow">▶</view>
    </view>
  </view>

  <!-- 英语启蒙模块 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">🎨 英语启蒙</text>
      <text class="section-more" bindtap="goToUpgrade">全部 ></text>
    </view>
    <scroll-view class="modules-scroll" scroll-x="true" enhanced="true" show-scrollbar="false">
      <view class="modules-row">
        <view class="module-card" wx:for="{{upgradeModules}}" wx:key="id"
              style="background: {{item.bg}}"
              bindtap="goToModule" data-path="{{item.path}}">
          <text class="module-emoji">{{item.emoji}}</text>
          <text class="module-title">{{item.title}}</text>
          <text class="module-count">{{item.count}}个</text>
          <view class="module-progress-bar">
            <view class="module-progress-fill" style="width: {{item.progress}}%"></view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- OPW 拼读模块 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">🔤 牛津自然拼读</text>
      <text class="section-more" bindtap="goToPhonics">全部 ></text>
    </view>
    <view class="phonics-row">
      <view class="phonics-card" wx:for="{{phonicsLevels}}" wx:key="id"
            style="background: {{item.color}}"
            bindtap="goToLevel" data-id="{{item.id}}">
        <text class="phonics-icon">{{item.icon}}</text>
        <text class="phonics-level">{{item.title}}</text>
        <text class="phonics-sub">{{item.subtitle}}</text>
        <text class="phonics-weeks">{{item.weeks}}周</text>
      </view>
    </view>
  </view>

  <!-- 快速入口 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">⚡ 快速入口</text>
    </view>
    <view class="quick-grid">
      <view class="quick-item" bindtap="goToInteractive">
        <text class="quick-emoji">🎮</text>
        <text class="quick-label">拼读练习</text>
      </view>
      <view class="quick-item" bindtap="goToGames">
        <text class="quick-emoji">🏆</text>
        <text class="quick-label">游戏中心</text>
      </view>
      <view class="quick-item" bindtap="goToProfile">
        <text class="quick-emoji">📊</text>
        <text class="quick-label">学习报告</text>
      </view>
      <view class="quick-item" bindtap="goToLessonPlan">
        <text class="quick-emoji">📋</text>
        <text class="quick-label">教案模板</text>
      </view>
    </view>
  </view>

  <view class="footer">
    <text>优格德幼儿英语 v1.0 · 让每一个孩子爱上英语</text>
  </view>

</view>
