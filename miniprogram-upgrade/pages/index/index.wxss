/* pages/index/index.wxss */

.page {
  padding-bottom: 40rpx;
  background: #F5F7FA;
}

/* ── Hero Banner ── */
.hero {
  position: relative;
  padding: 60rpx 32rpx 40rpx;
  background: linear-gradient(135deg, #003a8c 0%, #1976D2 60%, #42A5F5 100%);
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 80% 20%, rgba(255,255,255,0.15) 0%, transparent 60%);
}

.hero-content {
  position: relative;
  z-index: 2;
}

.hero-title {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.title-cn {
  font-size: 44rpx;
  font-weight: 900;
  color: #fff;
  letter-spacing: 4rpx;
}

.title-en {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  letter-spacing: 2rpx;
  font-weight: 600;
}

.hero-stats {
  display: flex;
  align-items: center;
  gap: 0;
  margin-top: 32rpx;
  background: rgba(255,255,255,0.15);
  border-radius: 20rpx;
  padding: 20rpx 0;
  backdrop-filter: blur(10px);
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stat-num {
  font-size: 44rpx;
  font-weight: 900;
  color: #FFD700;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
}

.stat-divider {
  width: 2rpx;
  height: 50rpx;
  background: rgba(255,255,255,0.3);
}

.hero-mascot {
  position: absolute;
  right: 32rpx;
  top: 40rpx;
  font-size: 80rpx;
  z-index: 3;
}

/* ── Section ── */
.section {
  margin: 32rpx 24rpx 0;
}

.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #222;
}

.section-sub {
  font-size: 22rpx;
  color: #999;
}

.section-more {
  font-size: 26rpx;
  color: #1976D2;
  font-weight: 600;
}

/* ── 今日推荐卡片 ── */
.daily-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(25,118,210,0.12);
}

.daily-emoji {
  font-size: 64rpx;
  width: 100rpx;
  text-align: center;
}

.daily-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.daily-word {
  font-size: 38rpx;
  font-weight: 900;
  color: #1976D2;
}

.daily-cn {
  font-size: 26rpx;
  color: #888;
}

.daily-arrow {
  font-size: 28rpx;
  color: #1976D2;
}

/* ── 启蒙模块横向滚动 ── */
.modules-scroll {
  width: 100%;
  white-space: nowrap;
}

.modules-row {
  display: flex;
  gap: 20rpx;
  padding: 8rpx 0 16rpx;
}

.module-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 190rpx;
  padding: 24rpx 16rpx 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.12);
  flex-shrink: 0;
  gap: 8rpx;
}

.module-emoji {
  font-size: 52rpx;
}

.module-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #fff;
  text-shadow: 0 1rpx 4rpx rgba(0,0,0,0.2);
}

.module-count {
  font-size: 22rpx;
  color: rgba(255,255,255,0.85);
}

.module-progress-bar {
  width: 100%;
  height: 8rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 4rpx;
  margin-top: 6rpx;
}

.module-progress-fill {
  height: 100%;
  background: rgba(255,255,255,0.9);
  border-radius: 4rpx;
  transition: width 0.5s;
}

/* ── OPW Level 卡片 ── */
.phonics-row {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding: 8rpx 0 16rpx;
}

.phonics-card {
  flex: 0 0 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.12);
  gap: 6rpx;
}

.phonics-icon {
  font-size: 44rpx;
}

.phonics-level {
  font-size: 28rpx;
  font-weight: 900;
  color: #fff;
}

.phonics-sub {
  font-size: 22rpx;
  color: rgba(255,255,255,0.9);
  font-weight: 600;
}

.phonics-weeks {
  font-size: 20rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 4rpx;
}

/* ── 快速入口 ── */
.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.quick-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  box-shadow: 0 4rpx 14rpx rgba(0,0,0,0.07);
}

.quick-emoji {
  font-size: 44rpx;
}

.quick-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #444;
}

/* ── Footer ── */
.footer {
  text-align: center;
  padding: 40rpx 0 20rpx;
  font-size: 22rpx;
  color: #bbb;
}

/* bounce动画 */
@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-14rpx); }
}
.bounce { animation: bounce 2s ease-in-out infinite; }
