/* pages/upgrade/abc/abc.wxss */
.page { padding: 0 0 40rpx; background: #F5F7FA; }

/* Tabs */
.tabs {
  display: flex;
  background: #fff;
  padding: 16rpx 24rpx;
  gap: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  position: sticky;
  top: 0;
  z-index: 99;
}
.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #999;
  background: #F5F7FA;
  transition: all 0.2s;
}
.tab.active {
  background: linear-gradient(135deg, #1976D2, #42A5F5);
  color: #fff;
  box-shadow: 0 4rpx 14rpx rgba(25,118,210,0.3);
}

/* Detail Card */
.detail-card {
  margin: 24rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.08);
  border: 3rpx solid transparent;
}
.detail-letter {
  font-size: 120rpx;
  font-weight: 900;
  line-height: 1;
  font-family: 'Courier New', monospace;
}
.detail-lower {
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1;
  margin-top: -16rpx;
}
.detail-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.detail-emoji { font-size: 52rpx; }
.detail-word { font-size: 36rpx; font-weight: 800; color: #222; }
.detail-cn { font-size: 26rpx; color: #888; }
.detail-sound {
  font-size: 24rpx;
  color: #1976D2;
  background: #E3F2FD;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  align-self: flex-start;
}
.speak-btn {
  margin-top: 12rpx;
  background: linear-gradient(135deg, #1976D2, #42A5F5);
  color: #fff;
  border-radius: 40rpx;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  font-weight: 700;
  text-align: center;
  align-self: flex-start;
  box-shadow: 0 4rpx 14rpx rgba(25,118,210,0.35);
}

/* ABC Grid */
.grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 16rpx;
  padding: 0 24rpx 24rpx;
}
.abc-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  border-radius: 20rpx;
  background: #fff;
  border: 3rpx solid #eee;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.06);
  position: relative;
  transition: all 0.2s;
}
.abc-card.selected {
  transform: scale(1.08);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}
.abc-upper { font-size: 36rpx; font-weight: 900; line-height: 1; }
.abc-lower { font-size: 22rpx; color: #aaa; }
.abc-emoji { font-size: 30rpx; }
.learned-dot {
  position: absolute;
  top: 6rpx;
  right: 8rpx;
  font-size: 18rpx;
  color: #43A047;
  font-weight: 900;
}

/* Quiz */
.quiz-box {
  margin: 24rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 40rpx 32rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.08);
}
.quiz-score-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 32rpx;
}
.quiz-score { font-size: 28rpx; font-weight: 800; color: #1976D2; }
.quiz-total { font-size: 26rpx; color: #999; }
.quiz-question {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 40rpx;
}
.quiz-q-label { font-size: 26rpx; color: #666; }
.quiz-q-emoji { font-size: 100rpx; }
.quiz-q-word { font-size: 44rpx; font-weight: 900; color: #222; }
.quiz-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}
.quiz-opt {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  border-radius: 20rpx;
  background: #F0F4FF;
  font-size: 44rpx;
  font-weight: 900;
  color: #1976D2;
  border: 3rpx solid #E3F2FD;
  transition: all 0.2s;
}
.quiz-opt.correct { background: #4CAF50; color: #fff; border-color: #4CAF50; }
.quiz-opt.wrong   { background: #E53935; color: #fff; border-color: #E53935; }
.quiz-next-btn {
  margin-top: 32rpx;
  background: linear-gradient(135deg, #1976D2, #42A5F5);
  color: #fff;
  border-radius: 50rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 6rpx 20rpx rgba(25,118,210,0.35);
}

/* Trace */
.trace-box {
  margin: 24rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.08);
}
.trace-nav {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 24rpx;
}
.trace-prev, .trace-next {
  width: 70rpx;
  height: 70rpx;
  background: #E3F2FD;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #1976D2;
}
.trace-current-letter {
  font-size: 80rpx;
  font-weight: 900;
}
.trace-guide {
  position: relative;
  width: 100%;
  height: 360rpx;
  background: #fafafa;
  border: 3rpx dashed #ddd;
  border-radius: 20rpx;
  overflow: hidden;
}
.trace-big-letter {
  position: absolute;
  font-size: 280rpx;
  font-weight: 900;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
  user-select: none;
  z-index: 0;
}
.trace-canvas {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}
.trace-tips {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin: 20rpx 0;
  font-size: 26rpx;
  color: #666;
  text-align: center;
}
.trace-controls {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}
.trace-clear-btn, .trace-say-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 20rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
}
.trace-clear-btn { background: #FFF3E0; color: #E65100; }
.trace-say-btn { background: #E3F2FD; color: #1976D2; }

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to   { opacity: 1; transform: translateY(0); }
}
.fade-in { animation: fadeInUp 0.3s ease forwards; }
