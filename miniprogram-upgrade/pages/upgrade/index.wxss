/* pages/upgrade/index.wxss */
.page { background: #F5F7FA; }
.hero { padding: 50rpx 32rpx 40rpx; }
.hero-title { display: block; font-size: 44rpx; font-weight: 900; color: #fff; }
.hero-sub { display: block; font-size: 26rpx; color: rgba(255,255,255,0.85); margin-top: 8rpx; }
.modules { padding: 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.module-item { background: #fff; border-radius: 24rpx; padding: 28rpx; display: flex; align-items: center; gap: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.07); }
.module-icon { width: 96rpx; height: 96rpx; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.module-emoji { font-size: 48rpx; }
.module-info { flex: 1; }
.module-title { display: block; font-size: 30rpx; font-weight: 800; color: #222; }
.module-desc { display: block; font-size: 24rpx; color: #999; margin-top: 4rpx; }
.module-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 6rpx; min-width: 100rpx; }
.module-count { font-size: 22rpx; color: #aaa; }
.prog-bar { width: 80rpx; height: 8rpx; background: #E3F2FD; border-radius: 4rpx; overflow: hidden; }
.prog-fill { height: 100%; background: #1976D2; border-radius: 4rpx; }
.prog-text { font-size: 20rpx; color: #1976D2; font-weight: 700; }
.arrow { font-size: 36rpx; color: #ccc; }
