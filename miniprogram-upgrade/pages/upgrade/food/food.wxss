/* 通用词汇页样式 */
.page { background: #F5F7FA; min-height: 100vh; }
.tabs { display:flex; background:#fff; padding:16rpx 24rpx; gap:12rpx; position:sticky; top:0; z-index:99; box-shadow:0 2rpx 12rpx rgba(0,0,0,0.06); }
.tab { flex:1; text-align:center; padding:16rpx 0; border-radius:16rpx; font-size:26rpx; font-weight:700; color:#999; background:#F5F7FA; }
.tab.active { background:linear-gradient(135deg,#4ECDC4,#44A08D); color:#fff; box-shadow:0 4rpx 14rpx rgba(78,205,196,0.35); }
.word-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:20rpx; padding:24rpx; }
.word-card { background:#fff; border-radius:24rpx; padding:24rpx 12rpx; display:flex; flex-direction:column; align-items:center; gap:10rpx; border:3rpx solid #eee; box-shadow:0 3rpx 12rpx rgba(0,0,0,0.07); position:relative; }
.word-card.selected { transform:scale(1.06); box-shadow:0 8rpx 24rpx rgba(0,0,0,0.14); }
.word-emoji { font-size:52rpx; }
.word-en { font-size:26rpx; font-weight:800; }
.word-cn { font-size:22rpx; color:#999; }
.check { position:absolute; top:8rpx; right:10rpx; font-size:20rpx; color:#43A047; font-weight:900; }
/* Popup */
.detail-popup { position:fixed; inset:0; background:rgba(0,0,0,0.45); display:flex; align-items:center; justify-content:center; opacity:0; pointer-events:none; z-index:200; transition:opacity 0.2s; }
.detail-popup.show { opacity:1; pointer-events:auto; }
.popup-card { background:#fff; border-radius:32rpx; padding:48rpx 40rpx; display:flex; flex-direction:column; align-items:center; gap:16rpx; width:560rpx; box-shadow:0 16rpx 60rpx rgba(0,0,0,0.2); }
.popup-emoji { font-size:100rpx; }
.popup-word { font-size:52rpx; font-weight:900; color:#222; }
.popup-cn { font-size:32rpx; color:#666; }
.popup-sound,.popup-usage { font-size:24rpx; color:#4ECDC4; }
.popup-btn { margin-top:16rpx; background:linear-gradient(135deg,#4ECDC4,#44A08D); color:#fff; border-radius:50rpx; padding:20rpx 60rpx; font-size:28rpx; font-weight:700; }
/* Quiz */
.quiz-wrap { padding:24rpx; }
.quiz-header { display:flex; justify-content:space-between; margin-bottom:24rpx; }
.quiz-score-text { font-size:28rpx; font-weight:800; color:#4ECDC4; }
.quiz-prog { font-size:26rpx; color:#999; }
.quiz-card { background:#fff; border-radius:28rpx; padding:40rpx 32rpx; box-shadow:0 8rpx 30rpx rgba(0,0,0,0.08); }
.quiz-label { display:block; font-size:26rpx; color:#888; text-align:center; margin-bottom:16rpx; }
.quiz-big { display:block; font-size:52rpx; font-weight:900; color:#222; text-align:center; }
.quiz-emoji-show { display:block; font-size:80rpx; text-align:center; margin:16rpx 0; }
.options-grid { display:grid; grid-template-columns:1fr 1fr; gap:20rpx; margin-top:16rpx; }
.opt { display:flex; align-items:center; justify-content:center; min-height:90rpx; border-radius:20rpx; background:#F0F4FF; font-size:28rpx; font-weight:700; color:#333; border:3rpx solid #E3F2FD; padding:12rpx; text-align:center; }
.opt.correct { background:#4CAF50; color:#fff; border-color:#4CAF50; }
.opt.wrong   { background:#E53935; color:#fff; border-color:#E53935; }
.next-btn { margin-top:32rpx; background:linear-gradient(135deg,#4ECDC4,#44A08D); color:#fff; border-radius:50rpx; padding:24rpx; text-align:center; font-size:30rpx; font-weight:700; }
