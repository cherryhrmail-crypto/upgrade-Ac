/* pages/phonics/interactive/interactive.wxss */
.page { background: #F5F7FA; padding-bottom: 50rpx; }
/* Level Tabs */
.level-tabs { display:flex; background:#1976D2; padding:16rpx 24rpx; gap:12rpx; }
.ltab { flex:1; text-align:center; padding:14rpx 0; border-radius:14rpx; font-size:26rpx; font-weight:800; color:rgba(255,255,255,0.7); background:rgba(255,255,255,0.1); }
.ltab.active { background:#fff; color:#1976D2; }
/* Mode Tabs */
.mode-tabs { display:flex; background:#fff; padding:16rpx 24rpx; gap:12rpx; box-shadow:0 2rpx 10rpx rgba(0,0,0,0.06); }
.mtab { flex:1; text-align:center; padding:16rpx 0; border-radius:16rpx; font-size:24rpx; font-weight:700; color:#999; background:#F5F7FA; }
.mtab.active { background:linear-gradient(135deg,#1976D2,#42A5F5); color:#fff; }
/* Score Row */
.score-row { display:flex; align-items:center; gap:16rpx; padding:20rpx 32rpx; }
.score-text { font-size:28rpx; font-weight:800; color:#F9A825; }
.combo-text { font-size:26rpx; font-weight:800; color:#E53935; flex:1; }
.progress-text { font-size:26rpx; color:#999; }
/* Quiz Card */
.quiz-card { margin:0 24rpx; background:#fff; border-radius:28rpx; padding:40rpx 32rpx; box-shadow:0 8rpx 30rpx rgba(0,0,0,0.08); }
.quiz-q { display:flex; flex-direction:column; align-items:center; gap:16rpx; margin-bottom:32rpx; }
.quiz-q-label { font-size:26rpx; color:#666; }
.sound-show { font-size:80rpx; font-weight:900; color:#1976D2; background:#E3F2FD; padding:16rpx 40rpx; border-radius:24rpx; }
.quiz-opts { display:grid; grid-template-columns:1fr 1fr; gap:20rpx; }
.quiz-opt { display:flex; align-items:center; justify-content:center; height:90rpx; border-radius:20rpx; background:#F0F4FF; border:3rpx solid #E3F2FD; }
.opt-word { font-size:36rpx; font-weight:800; color:#333; }
.quiz-opt.correct { background:#4CAF50; border-color:#4CAF50; }
.quiz-opt.correct .opt-word { color:#fff; }
.quiz-opt.wrong { background:#E53935; border-color:#E53935; }
.quiz-opt.wrong .opt-word { color:#fff; }
.next-btn { margin-top:32rpx; background:linear-gradient(135deg,#1976D2,#42A5F5); color:#fff; border-radius:50rpx; padding:24rpx; text-align:center; font-size:30rpx; font-weight:700; }
/* Build Card */
.build-card { margin:0 24rpx; background:#fff; border-radius:28rpx; padding:40rpx 32rpx; box-shadow:0 8rpx 30rpx rgba(0,0,0,0.08); text-align:center; }
.build-hint { display:block; font-size:26rpx; color:#888; margin-bottom:16rpx; }
.build-emoji { display:block; font-size:100rpx; }
.build-meaning { display:block; font-size:30rpx; color:#666; margin-bottom:32rpx; }
.build-answer { display:flex; justify-content:center; gap:12rpx; margin-bottom:32rpx; }
.build-slot { width:72rpx; height:80rpx; border-radius:14rpx; border:3rpx dashed #ddd; display:flex; align-items:center; justify-content:center; font-size:36rpx; font-weight:900; }
.build-letters { display:flex; flex-wrap:wrap; justify-content:center; gap:16rpx; margin-bottom:32rpx; }
.build-letter { width:80rpx; height:80rpx; background:#E3F2FD; border-radius:16rpx; display:flex; align-items:center; justify-content:center; font-size:36rpx; font-weight:900; color:#1976D2; }
.build-letter.used { opacity:0.3; }
.build-actions { display:flex; gap:20rpx; }
.build-clear { flex:1; padding:20rpx; border-radius:20rpx; background:#FFF3E0; color:#E65100; font-size:28rpx; font-weight:700; text-align:center; }
.build-check { flex:2; padding:20rpx; border-radius:20rpx; background:linear-gradient(135deg,#1976D2,#42A5F5); color:#fff; font-size:28rpx; font-weight:700; text-align:center; }
/* Blend Card */
.blend-card { margin:0 24rpx; background:#fff; border-radius:28rpx; padding:40rpx 32rpx; box-shadow:0 8rpx 30rpx rgba(0,0,0,0.08); text-align:center; }
.blend-word { display:block; font-size:72rpx; font-weight:900; color:#222; }
.blend-cn { display:block; font-size:28rpx; color:#888; margin-bottom:32rpx; }
.blend-phonemes { display:flex; justify-content:center; gap:16rpx; margin-bottom:28rpx; }
.blend-ph { background:#E3F2FD; border-radius:20rpx; padding:20rpx 28rpx; display:flex; flex-direction:column; align-items:center; gap:8rpx; }
.ph-text { font-size:40rpx; font-weight:900; color:#1976D2; }
.ph-icon { font-size:24rpx; }
.blend-eq { display:flex; align-items:center; justify-content:center; gap:8rpx; margin-bottom:32rpx; flex-wrap:wrap; }
.blend-ph-text { font-size:32rpx; font-weight:700; color:#1976D2; }
.blend-plus { font-size:32rpx; color:#999; }
.blend-result { font-size:36rpx; font-weight:900; color:#E53935; }
.blend-say { background:linear-gradient(135deg,#1976D2,#42A5F5); color:#fff; border-radius:50rpx; padding:22rpx 60rpx; font-size:28rpx; font-weight:700; display:inline-block; margin-bottom:16rpx; }
.blend-next { background:#F0F4FF; color:#1976D2; border-radius:50rpx; padding:18rpx 50rpx; font-size:26rpx; font-weight:700; display:inline-block; }
