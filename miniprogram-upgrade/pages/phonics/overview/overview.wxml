<!-- pages/phonics/overview/overview.wxml — OPW总览 -->
<view class="page">
  <view class="hero">
    <view class="hero-text">
      <text class="hero-title">🔤 Oxford Phonics World</text>
      <text class="hero-sub">牛津自然拼读 · 5册 · 110周 · 1800+词</text>
    </view>
    <view class="hero-stats">
      <view class="hstat"><text class="hnum">5</text><text class="hlabel">册</text></view>
      <view class="hstat"><text class="hnum">110</text><text class="hlabel">周</text></view>
      <view class="hstat"><text class="hnum">1800+</text><text class="hlabel">词汇</text></view>
      <view class="hstat"><text class="hnum">90min</text><text class="hlabel">每课</text></view>
    </view>
  </view>

  <!-- 5个Level卡片 -->
  <view class="levels-section">
    <view class="level-card" wx:for="{{levels}}" wx:key="id"
          style="background: linear-gradient(135deg, {{item.color}}, {{item.color}}99)"
          bindtap="goToLevel" data-id="{{item.id}}">
      <view class="lc-header">
        <text class="lc-icon">{{item.icon}}</text>
        <view class="lc-badge">Level {{item.id}}</view>
      </view>
      <text class="lc-title">{{item.subtitle}}</text>
      <text class="lc-desc">{{item.desc}}</text>
      <view class="lc-meta">
        <text class="lc-meta-item">{{item.age}}</text>
        <text class="lc-meta-item">{{item.weeks}}周</text>
        <text class="lc-meta-item">{{item.words}}词</text>
      </view>
      <view class="lc-progress">
        <view class="lc-prog-fill" style="width: {{item.progress}}%"></view>
      </view>
    </view>
  </view>

  <!-- 互动练习入口 -->
  <view class="practice-banner" bindtap="goToInteractive">
    <text class="pb-emoji">🎮</text>
    <view class="pb-text">
      <text class="pb-title">拼读互动练习</text>
      <text class="pb-sub">测验 · 构词 · 拼读游戏</text>
    </view>
    <text class="pb-arrow">›</text>
  </view>

  <!-- 教案模板入口 -->
  <view class="lesson-banner" bindtap="goToLesson">
    <text class="lb-emoji">📋</text>
    <view class="lb-text">
      <text class="lb-title">90分钟教案模板</text>
      <text class="lb-sub">6个教学环节 · 完整流程设计</text>
    </view>
    <text class="lb-arrow">›</text>
  </view>
</view>
