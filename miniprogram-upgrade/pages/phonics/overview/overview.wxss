/* pages/phonics/overview/overview.wxss */
.page { background: #F5F7FA; padding-bottom: 40rpx; }
.hero { background: linear-gradient(135deg, #1565C0, #1976D2, #42A5F5); padding: 50rpx 32rpx 40rpx; }
.hero-text { margin-bottom: 28rpx; }
.hero-title { display: block; font-size: 38rpx; font-weight: 900; color: #fff; }
.hero-sub { display: block; font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; }
.hero-stats { display: flex; background: rgba(255,255,255,0.15); border-radius: 20rpx; padding: 20rpx 0; }
.hstat { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4rpx; }
.hnum { font-size: 36rpx; font-weight: 900; color: #FFD700; }
.hlabel { font-size: 22rpx; color: rgba(255,255,255,0.8); }
/* Level Cards */
.levels-section { padding: 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.level-card { border-radius: 28rpx; padding: 32rpx; box-shadow: 0 8rpx 28rpx rgba(0,0,0,0.12); }
.lc-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 12rpx; }
.lc-icon { font-size: 44rpx; }
.lc-badge { background: rgba(255,255,255,0.3); color: #fff; font-size: 24rpx; font-weight: 800; padding: 6rpx 18rpx; border-radius: 20rpx; }
.lc-title { display: block; font-size: 34rpx; font-weight: 900; color: #fff; margin-bottom: 8rpx; }
.lc-desc { display: block; font-size: 24rpx; color: rgba(255,255,255,0.85); margin-bottom: 16rpx; }
.lc-meta { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.lc-meta-item { background: rgba(255,255,255,0.2); color: #fff; font-size: 22rpx; font-weight: 700; padding: 5rpx 16rpx; border-radius: 16rpx; }
.lc-progress { height: 8rpx; background: rgba(255,255,255,0.25); border-radius: 4rpx; }
.lc-prog-fill { height: 100%; background: rgba(255,255,255,0.85); border-radius: 4rpx; }
/* Practice Banner */
.practice-banner, .lesson-banner {
  margin: 0 24rpx 20rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.07);
}
.pb-emoji, .lb-emoji { font-size: 52rpx; }
.pb-text, .lb-text { flex: 1; }
.pb-title, .lb-title { display: block; font-size: 30rpx; font-weight: 800; color: #222; }
.pb-sub, .lb-sub { display: block; font-size: 24rpx; color: #999; margin-top: 4rpx; }
.pb-arrow, .lb-arrow { font-size: 40rpx; color: #ccc; }
